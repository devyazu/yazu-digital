# Gemini API anahtarı (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — Project Settings → API sayfasından alın
# Project URL ve anon public key (detay: SUPABASE_KURULUM.md)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# İsteğe bağlı: Yerel API proxy portu (varsayılan 3001)
# API_PORT=3001
